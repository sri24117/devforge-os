{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "VITE_API_URL": "https://devforge-api.onrender.com",
    "VITE_MICROSERVICE_URL": "https://devforge-microservice.onrender.com"
  }
}
