# ──────────────────────────────────────────────────────────────
#  DevForge OS — Environment Variables
#  Copy to .env and fill in values. Never commit .env to git!
# ──────────────────────────────────────────────────────────────

# ── AI ─────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
OLLAMA_URL=http://host.docker.internal:11434

# ── PostgreSQL ─────────────────────────────────────────────────
# Local (Docker)
DATABASE_URL=postgresql+asyncpg://devforge:devforge@localhost:5432/devforge
# Production (Supabase free tier)
# DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# ── Redis ──────────────────────────────────────────────────────
# Local (Docker)
REDIS_URL=redis://localhost:6379/0
# Production (Upstash free tier)
# REDIS_URL=rediss://default:[TOKEN]@[HOST].upstash.io:6379

# ── Frontend (Vite) ────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_MICROSERVICE_URL=http://localhost:5001
# Production:
# VITE_API_URL=https://devforge-api.onrender.com
# VITE_MICROSERVICE_URL=https://devforge-ms.onrender.com

# V4 OpenRouter AI Assistant
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=DevForge OS
AI_QUICK_MODEL=google/gemma-2-9b-it:free
AI_BALANCED_MODEL=openai/gpt-4o-mini
AI_DEEP_MODEL=anthropic/claude-3.5-sonnet
FREE_AI_DAILY_LIMIT=10
PRO_AI_DAILY_LIMIT=100
PREMIUM_AI_DAILY_LIMIT=300
FREE_COMPILER_DAILY_LIMIT=20
PRO_COMPILER_DAILY_LIMIT=150
PREMIUM_COMPILER_DAILY_LIMIT=500

# V5 execution reliability
# false = reliable local practice runner; true = strict CPU/file limits where supported
# For public SaaS, use Judge0 or a throwaway Docker sandbox instead of local subprocess.
EXECUTION_STRICT_LIMITS=false

# Future payments / feature gates
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=


# V6 production integrations
EXECUTION_BACKEND=local # local | docker | judge0
JUDGE0_API_URL=
JUDGE0_API_KEY=
JUDGE0_PYTHON_LANGUAGE_ID=71
DOCKER_PYTHON_IMAGE=python:3.12-alpine
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/v6/github/callback
GITHUB_OAUTH_STATE_SECRET=change-me
ADMIN_EMAILS=admin@example.com
MAX_RESUME_UPLOAD_MB=4
